{
  "info": {
    "name": "Banco API Full Test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('token')) {",
          "  pm.sendRequest({",
          "    url: pm.collectionVariables.get('baseUrl') + '/auth/login',",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/json' },",
          "    body: {",
          "      mode: 'raw',",
          "      raw: JSON.stringify({",
          "        email: 'admin@banco.com',",
          "        password: 'admin123'",
          "      })",
          "    }",
          "  }, function (err, res) {",
          "    if (res && res.json().access_token) {",
          "      pm.collectionVariables.set('token', res.json().access_token);",
          "    }",
          "  });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"]},
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Banco Admin2\",\n  \"email\": \"admin2@banco.com\",\n  \"username\": \"admin2\",\n  \"password\": \"admin123\"\n}"}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"]},
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@banco.com\",\n  \"password\": \"admin123\"\n}"}
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        { "name": "Create", "request": {"method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/clients", "host": ["{{baseUrl}}"], "path": ["clients"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"Carlos Cliente\",\n  \"email\": \"carlos.cliente@banco.com\",\n  \"address\": \"Calle 123\",\n  \"phone\": \"555-1234\"\n}"}} },
        { "name": "Get All", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/clients", "host": ["{{baseUrl}}"], "path": ["clients"]} } },
        { "name": "Get By Id", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/clients/1", "host": ["{{baseUrl}}"], "path": ["clients", "1"]} } },
        { "name": "Update", "request": {"method": "PATCH", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/clients/1", "host": ["{{baseUrl}}"], "path": ["clients", "1"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"Carlos Cliente Actualizado\"\n}"}} },
        { "name": "Delete", "request": {"method": "DELETE", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/clients/2", "host": ["{{baseUrl}}"], "path": ["clients", "2"]} } }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        { "name": "Create", "request": {"method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/accounts", "host": ["{{baseUrl}}"], "path": ["accounts"]}, "body": {"mode": "raw", "raw": "{\n  \"number\": \"ACC123\",\n  \"type\": \"SAVINGS\",\n  \"balance\": 1000,\n  \"clientId\": 1\n}"}} },
        { "name": "Get All", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/accounts", "host": ["{{baseUrl}}"], "path": ["accounts"]} } },
        { "name": "Get By Id", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/accounts/1", "host": ["{{baseUrl}}"], "path": ["accounts", "1"]} } },
        { "name": "Update", "request": {"method": "PATCH", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/accounts/1", "host": ["{{baseUrl}}"], "path": ["accounts", "1"]}, "body": {"mode": "raw", "raw": "{\n  \"balance\": 2000\n}"}} },
        { "name": "Delete", "request": {"method": "DELETE", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/accounts/3", "host": ["{{baseUrl}}"], "path": ["accounts", "3"]} } }
      ]
    },
    {
      "name": "Advisors",
      "item": [
        { "name": "Create", "request": {"method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/advisors", "host": ["{{baseUrl}}"], "path": ["advisors"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"Ana Asesora\",\n  \"email\": \"ana.asesora@banco.com\",\n  \"phone\": \"555-5678\",\n  \"userId\": 1\n}"}} },
        { "name": "Get All", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/advisors", "host": ["{{baseUrl}}"], "path": ["advisors"]} } },
        { "name": "Get By Id", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/advisors/1", "host": ["{{baseUrl}}"], "path": ["advisors", "1"]} } },
        { "name": "Update", "request": {"method": "PATCH", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/advisors/1", "host": ["{{baseUrl}}"], "path": ["advisors", "1"]}, "body": {"mode": "raw", "raw": "{\n  \"phone\": \"555-9999\"\n}"} } },
        { "name": "Delete", "request": {"method": "DELETE", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/advisors/1", "host": ["{{baseUrl}}"], "path": ["advisors", "1"]} } }
