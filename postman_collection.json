    {
      "name": "AccountTypes",
      "item": [
        { "name": "Create", "request": {"method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/account-types", "host": ["{{baseUrl}}"], "path": ["account-types"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"Premium\",\n  \"productId\": 1\n}"}} },
        { "name": "Get All", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/account-types", "host": ["{{baseUrl}}"], "path": ["account-types"]} } },
        { "name": "Get By Id", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/account-types/1", "host": ["{{baseUrl}}"], "path": ["account-types", "1"]} } },
        { "name": "Update", "request": {"method": "PATCH", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/account-types/1", "host": ["{{baseUrl}}"], "path": ["account-types", "1"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"Premium Actualizado\"\n}"} } },
        { "name": "Delete", "request": {"method": "DELETE", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/account-types/1", "host": ["{{baseUrl}}"], "path": ["account-types", "1"]} } }
      ]
    },
    {
      "name": "FinancialPeriods",
      "item": [
        { "name": "Create", "request": {"method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/financial-periods", "host": ["{{baseUrl}}"], "path": ["financial-periods"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"2026-Q1\",\n  \"startDate\": \"2026-01-01T00:00:00Z\",\n  \"endDate\": \"2026-03-31T23:59:59Z\"\n}"}} },
        { "name": "Get All", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/financial-periods", "host": ["{{baseUrl}}"], "path": ["financial-periods"]} } },
        { "name": "Get By Id", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/financial-periods/1", "host": ["{{baseUrl}}"], "path": ["financial-periods", "1"]} } },
        { "name": "Update", "request": {"method": "PATCH", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/financial-periods/1", "host": ["{{baseUrl}}"], "path": ["financial-periods", "1"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"2026-Q1 Actualizado\"\n}"} } },
        { "name": "Delete", "request": {"method": "DELETE", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/financial-periods/1", "host": ["{{baseUrl}}"], "path": ["financial-periods", "1"]} } }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        { "name": "Create", "request": {"method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"]}, "body": {"mode": "raw", "raw": "{\n  \"originAccountId\": 1,\n  \"destinationAccountId\": 2,\n  \"amount\": 500,\n  \"description\": \"Pago de servicios\"\n}"}} },
        { "name": "Get All", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"]} } },
        { "name": "Get By Id", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"]} } },
        { "name": "Update", "request": {"method": "PATCH", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"]}, "body": {"mode": "raw", "raw": "{\n  \"amount\": 750\n}"}} },
        { "name": "Delete", "request": {"method": "DELETE", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"]} } }
      ]
    },
    {
      "name": "Products",
      "item": [
        { "name": "Create", "request": {"method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"]}, "body": {"mode": "raw", "raw": "{\n  \"name\": \"Tarjeta Oro\",\n  \"type\": \"Credit Card\",\n  \"description\": \"Tarjeta de crédito premium\"\n}"} } },
        { "name": "Get All", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"]} } },
        { "name": "Get By Id", "request": {"method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/products/1", "host": ["{{baseUrl}}"], "path": ["products", "1"]} } },
        { "name": "Update", "request": {"method": "PATCH", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/products/1", "host": ["{{baseUrl}}"], "path": ["products", "1"]}, "body": {"mode": "raw", "raw": "{\n  \"description\": \"Tarjeta actualizada\"\n}"} } },
        { "name": "Delete", "request": {"method": "DELETE", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/products/1", "host": ["{{baseUrl}}"], "path": ["products", "1"]} } }
      ]
    },
    {
      "name": "Consultas Especiales",
      "item": [
        { "name": "Clientes activos con cuentas", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/clients/active-with-accounts", "host": ["{{baseUrl}}"], "path": ["clients", "active-with-accounts"]}, "description": "Retorna clientes activos con sus cuentas asociadas" } },
        { "name": "Cuentas de un cliente", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/accounts/by-client/1", "host": ["{{baseUrl}}"], "path": ["accounts", "by-client", "1"]}, "description": "Retorna todas las cuentas de un cliente específico" } },
        { "name": "Asesores con 2+ cuentas", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/advisors/multiple-accounts", "host": ["{{baseUrl}}"], "path": ["advisors", "multiple-accounts"]}, "description": "Retorna asesores que gestionan 2 o más cuentas" } },
        { "name": "Transacciones por cuenta y periodo", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions/account/1/period/1", "host": ["{{baseUrl}}"], "path": ["transactions", "account", "1", "period", "1"]}, "description": "Retorna transacciones de una cuenta en un periodo financiero" } }
      ]
    },
    {
      "name": "Filtros y Reportes",
      "item": [
        { "name": "Filtrar clientes (AND)", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/clients/filter?accountTypeId=1&periodId=1", "host": ["{{baseUrl}}"], "path": ["clients", "filter"], "query": [{"key": "accountTypeId", "value": "1"}, {"key": "periodId", "value": "1"}]}, "description": "Filtra clientes activos con cuentas de un tipo y transacciones en un periodo usando operador AND" } },
        { "name": "Filtrar asesores (AND/OR/NOT)", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/advisors/filter-complex", "host": ["{{baseUrl}}"], "path": ["advisors", "filter-complex"]}, "description": "Filtra asesores tiempo completo que gestionan cuentas O están activos usando operadores AND, OR, NOT" } },
        { "name": "Reporte SQL nativo", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions/report", "host": ["{{baseUrl}}"], "path": ["transactions", "report"]}, "description": "Genera reporte con SQL nativo usando $queryRaw de Prisma" } }
      ]
    },
    {
      "name": "Transacciones ACID",
      "item": [
        { "name": "Crear transacción (ACID)", "request": { "method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "body": {"mode": "raw", "raw": "{\n  \"originAccountId\": 1,\n  \"destinationAccountId\": 2,\n  \"amount\": 500,\n  \"description\": \"Pago de servicios\",\n  \"transactionAt\": \"2026-02-25T20:00:00Z\"\n}"}, "url": {"raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"]}, "description": "Crea transacción con control ACID: Atomicidad, Consistencia, Aislamiento, Durabilidad. Una transacción ACID garantiza que todas las operaciones bancarias sean atómicas (todo o nada), consistentes (el estado del sistema siempre es válido), aisladas (no afectan otras transacciones concurrentes) y durables (los cambios persisten ante fallos)." } },
        { "name": "Verificar transacción creada", "request": { "method": "GET", "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "url": {"raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"]}, "description": "Lista todas las transacciones para verificar la creación exitosa" } },
        { "name": "Intentar transacción duplicada (Debe fallar)", "request": { "method": "POST", "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ], "body": {"mode": "raw", "raw": "{\n  \"originAccountId\": 1,\n  \"destinationAccountId\": 2,\n  \"amount\": 500,\n  \"description\": \"Pago de servicios\",\n  \"transactionAt\": \"2026-02-25T20:00:00Z\"\n}"}, "url": {"raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"]}, "description": "Intenta crear la misma transacción nuevamente. Debe retornar error 409 Conflict" } }
      ]
